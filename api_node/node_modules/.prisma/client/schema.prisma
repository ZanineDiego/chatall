datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

// ==========================================
// 1. ENTIDADE MASTER DE USUÁRIO
// ==========================================
model User {
  id       String  @id @default(uuid())
  email    String  @unique
  password String
  isAdmin  Boolean @default(false) // Permite login no App de Moderação

  // --- TRAVA DE SEGURANÇA DA MODERAÇÃO ---
  isFlagged Boolean @default(false) // Protege contra deleção automática

  createdAt    DateTime @default(now())
  lastActiveAt DateTime @default(now())

  // Relacionamentos básicos
  profile      Profile?
  chatsAsUser1 MatchHistory[] @relation("User1Chats")
  chatsAsUser2 MatchHistory[] @relation("User2Chats")
  messages     ChatMessage[]

  // Relacionamentos focados em Moderação
  reportsFiled    Report[]        @relation("ReporterRelation") // Denúncias que este usuário FEZ
  reportsReceived Report[]        @relation("OffenderRelation") // Denúncias que este usuário RECEBEU
  actionsTaken    ModerationLog[] @relation("AdminActions") // Ações se ele for um Admin

  @@index([id])
  @@index([isFlagged])
}

// ==========================================
// 2. PERFIL DE IDENTIFICAÇÃO (ID, GÊNERO, IDADE)
// ==========================================
model Profile {
  id     String @id @default(uuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  nickname String
  realName String?
  photoUrl String? // Foto vinculada diretamente ao ID
  myGender String
  myAge    Int

  searchingForGender String @default("all")
  minAge             Int    @default(18)
  maxAge             Int    @default(99)

  updatedAt DateTime @updatedAt

  @@index([myGender, myAge])
}

// ==========================================
// 3. HISTÓRICO DE CONVERSAS (CHAVE MESTRA)
// ==========================================
model MatchHistory {
  id            String   @id @default(uuid())
  roomId        String   @unique // Mesmo ID gerado no Redis
  user1Id       String
  user2Id       String
  createdAt     DateTime @default(now())
  lastMessageAt DateTime @default(now())

  // --- TRAVA DE SEGURANÇA DA CONVERSA ---
  isFrozen Boolean @default(false) // Protege este chat específico do robô de 45 dias

  user1    User          @relation("User1Chats", fields: [user1Id], references: [id], onDelete: Cascade)
  user2    User          @relation("User2Chats", fields: [user2Id], references: [id], onDelete: Cascade)
  messages ChatMessage[]
  reports  Report[] // Denúncias vinculadas a esta conversa

  @@index([roomId])
  @@index([user1Id, user2Id])
  @@index([createdAt, lastMessageAt])
  @@index([isFrozen])
}

// ==========================================
// 4. HISTÓRICO DE MENSAGENS E MÍDIAS
// ==========================================
model ChatMessage {
  id       String       @id @default(uuid())
  roomId   String
  match    MatchHistory @relation(fields: [roomId], references: [roomId], onDelete: Cascade)
  senderId String
  sender   User         @relation(fields: [senderId], references: [id], onDelete: Cascade)

  content   String   @db.Text
  mediaType String   @default("text")
  createdAt DateTime @default(now())

  @@index([roomId])
  @@index([senderId])
}

// ==========================================
// 5. NOVA TABELA: PAINEL DE DENÚNCIAS (FLUXO DO APP ADMIN)
// ==========================================
model Report {
  id     String       @id @default(uuid())
  roomId String // O ID da sala onde ocorreu a infração
  match  MatchHistory @relation(fields: [roomId], references: [roomId], onDelete: Cascade)

  reporterId String // Quem denunciou
  reporter   User   @relation("ReporterRelation", fields: [reporterId], references: [id], onDelete: Cascade)

  offenderId String // O acusado
  offender   User   @relation("OffenderRelation", fields: [offenderId], references: [id], onDelete: Cascade)

  reason    String // Motivo: 'assédio', 'nudez', 'menor de idade', etc.
  status    String   @default("PENDING") // 'PENDING' | 'INVESTIGATING' | 'RESOLVED'
  createdAt DateTime @default(now())

  @@index([status])
  @@index([offenderId])
}

// ==========================================
// 6. NOVA TABELA: AUDITORIA INTERNA DOS MODERADORES
// ==========================================
model ModerationLog {
  id      String @id @default(uuid())
  adminId String // O ID do moderador que realizou a ação
  admin   User   @relation("AdminActions", fields: [adminId], references: [id], onDelete: Cascade)

  action    String // 'SPY_ROOM' | 'FLAG_USER' | 'FREEZE_CHAT' | 'BAN_USER'
  targetId  String // ID do usuário ou da sala que sofreu a ação
  details   String? // Justificativa ou notas do moderador
  createdAt DateTime @default(now())

  @@index([adminId])
}
